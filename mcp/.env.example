# Daily API (for telephony)
DAILY_API_KEY=

# Bot service URL (Cloud Run URL for paty-bot, or http://localhost:8080 for local dev)
BOT_SERVICE_URL=

# Authentication (required by default)
# Set MCP_API_KEY for static Bearer token auth, or use Clerk JWT auth (see below)
MCP_API_KEY=
# MCP_AUTH_DISABLED=true

# Clerk JWT authentication (alternative to MCP_API_KEY)
# Get these from https://dashboard.clerk.com → API Keys
CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json
CLERK_ISSUER=https://<your-clerk-domain>
CLERK_AUDIENCE=
